# This package needs NO install scripts: the primary store is Node's built-in
# node:sqlite (no native build) and the optional vector index is PGlite (WASM).
# Keeping this explicit is harmless and documents intent — but note the REAL
# install blocker is pi's `install-scripts` allowlist, not npm's `ignore-scripts`
# flag (see docs/specs + .claude/plans/backend-pglite-sqlite.md). The only dep
# that ever wanted a script was better-sqlite3, which has been removed.
ignore-scripts=false
