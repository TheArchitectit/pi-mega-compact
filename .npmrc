# Force lifecycle scripts for this package so the native addons build.
# Without this, a user/global `ignore-scripts=true` (common in locked-down or
# CI installs) silently skips the node-gyp build for better-sqlite3 and
# @mongodb-js/zstd, producing a missing binary and a load crash (Fix A).
# This local setting overrides the global ignore-scripts for THIS project only.
ignore-scripts=false
